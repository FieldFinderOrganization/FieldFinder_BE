# DATABASE MYSQL (AIVEN CLOUD)
DB_URL=jdbc:mysql://<HOST>:<PORT>/fieldfinder?ssl-mode=REQUIRED
DB_USERNAME=avnadmin
DB_PASSWORD=your_password_here

# MONGODB (ATLAS CLOUD)
MONGO_DB_PASSWORD=your_mongo_password_here

# PAYOS (kênh THU tiền)
YOUR_CLIENT_ID=your_client_id
YOUR_API_KEY=your_api_key
YOUR_CHECKSUM_KEY=your_checksum_key


PAYBACK_PROVIDER=payos
PAYBACK_CLIENT_ID=your_payout_client_id
PAYBACK_API_KEY=your_payout_api_key
PAYBACK_CHECKSUM_KEY=your_payout_checksum_key
REFUND_PAYOUT_DEADLINE_HOURS=24
REFUND_PAYOUT_MAX_ATTEMPTS=5

# BANK LOOKUP (tra cứu tên chủ TK — xác thực số TK là THẬT, qua BankLookup.net)
# BANK_LOOKUP_ENABLED=false ⇒ tắt tra cứu. =true ⇒ gọi BankLookup.net khi user tạo TK.
BANK_LOOKUP_ENABLED=true
BANK_LOOKUP_API_KEY=your_banklookup_api_key
BANK_LOOKUP_SECRET=your_banklookup_api_secret

# CLOUDINARY
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# EMAIL
MAIL_PASS=your_app_password_here

# SECURITY
JWT_SECRET=your_random_secret_string

# SOCIAL LOGIN
GOOGLE_CLIENT_ID=your_google_id
FACEBOOK_APP_ID=your_fb_id
FACEBOOK_APP_SECRET=your_fb_secret

# WAREHOUSE
WAREHOUSE_LAT=your_warehouse_latitude_here
WAREHOUSE_LNG=your_warehouse_longitude_here
WAREHOUSE_NAME=your_warehouse_name_here
WAREHOUSE_ADDRESS=your_warehouse_address_here

# OSRM
OSRM_BASE_URL=http://localhost:5000
OSRM_ENABLED=true

# SHIPPING (phí ship theo khoảng cách; freeship đơn >= threshold trong bán kính freeship-max-km)
SHIPPING_BASE_FEE=15000
SHIPPING_PER_KM_FEE=5000
SHIPPING_FREE_RADIUS_KM=2
SHIPPING_MIN_FEE=15000
SHIPPING_MAX_FEE=50000
SHIPPING_FREE_ORDER_THRESHOLD=500000
SHIPPING_FREESHIP_MAX_KM=20
SHIPPING_ROAD_FACTOR=1.3
